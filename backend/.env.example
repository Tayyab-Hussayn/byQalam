APP_ENV=local
APP_NAME=Qalam API
APP_DEBUG=true
APP_API_PREFIX=/api/v1
APP_FRONTEND_URL=http://localhost:3000
# Production example:
# APP_CORS_ORIGINS=https://app.byqalam.com,https://www.byqalam.com
APP_CORS_ORIGINS=http://localhost:3000

# Local Docker/Postgres example:
# DATABASE_URL=
#
# Supabase hosted Postgres example:
# Use the Session pooler URL from Supabase Dashboard > Connect, then convert
# postgresql:// or postgres:// to postgresql+asyncpg:// for SQLAlchemy asyncpg.
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qalam
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_CONNECT_TIMEOUT_SECONDS=10

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_JWKS_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=qalam-media

JWT_AUDIENCE=authenticated
JWT_ISSUER=
COOKIE_DOMAIN=

ENCRYPTION_KEY=replace-with-fernet-key
# Use a real Fernet key in production; this placeholder is for local setup only.
TOKEN_ENCRYPTION_KEY_ID=local

AI_DEFAULT_PROVIDER=mock
AI_DEFAULT_MODEL=mock-qalam-v1
AI_FALLBACK_PROVIDER=
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/linkedin/oauth/callback
LINKEDIN_OAUTH_SCOPES="openid profile email w_member_social"
LINKEDIN_API_VERSION=202604

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

SENTRY_DSN=
LOG_LEVEL=INFO
RATE_LIMIT_BACKEND=redis

ENABLE_LINKEDIN_PUBLISHING=false
ENABLE_LINKEDIN_COMPANY_PAGES=false
ENABLE_MEDIA_UPLOADS=false
ENABLE_STRIPE_BILLING=false
ENABLE_AI_GENERATION=true
ENABLE_BACKGROUND_GENERATION=false
ENABLE_RATE_LIMITING=true

FREE_MONTHLY_AI_GENERATIONS=20
FREE_MONTHLY_SCHEDULED_POSTS=5
FREE_MAX_WORKSPACES=1
FREE_MAX_MEMBERS=1
FREE_MAX_LINKEDIN_CONNECTIONS=0
FREE_MEDIA_STORAGE_MB=50

STARTER_MONTHLY_AI_GENERATIONS=300
STARTER_MONTHLY_SCHEDULED_POSTS=100
STARTER_MAX_WORKSPACES=1
STARTER_MAX_MEMBERS=2
STARTER_MAX_LINKEDIN_CONNECTIONS=1
STARTER_MEDIA_STORAGE_MB=500

PRO_MONTHLY_AI_GENERATIONS=1000
PRO_MONTHLY_SCHEDULED_POSTS=500
PRO_MAX_WORKSPACES=3
PRO_MAX_MEMBERS=5
PRO_MAX_LINKEDIN_CONNECTIONS=3
PRO_MEDIA_STORAGE_MB=5000

AGENCY_MONTHLY_AI_GENERATIONS=5000
AGENCY_MONTHLY_SCHEDULED_POSTS=2500
AGENCY_MAX_WORKSPACES=50
AGENCY_MAX_MEMBERS=25
AGENCY_MAX_LINKEDIN_CONNECTIONS=50
AGENCY_MEDIA_STORAGE_MB=50000
